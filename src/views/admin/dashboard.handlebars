<div class="home-page">
  {{!-- 1. Admin Hero Section: High-Level Stats --}}
  <div class="home-hero">
    <div class="eyebrow">Administrative Access</div>
    <h1>God View Control Center</h1>
    <p>Monitor system health, moderate community content, and view accountability logs.</p>
    
    <div class="home-actions">
      <div class="home-card">
        <h2>{{stats.users}}</h2>
        <p>Total Members</p>
      </div>
      <div class="home-card">
        <h2>{{stats.posts}}</h2>
        <p>Community Posts</p>
      </div>
      <div class="home-card">
        <h2>{{stats.reviews}}</h2>
        <p>Community Reviews</p>
      </div>
      <div class="home-card">
        <h2>{{stats.lastSync}}</h2>
        <p>Last Activity Sync</p>
      </div>
    </div>
  </div>

  {{!-- 2. Quick Action: Add Restaurant Form --}}
  <section class="home-info-panel" style="margin-top: 2rem;">
    <div class="eyebrow">Database Injection</div>
    <h2>Quick Add Restaurant</h2>
    <form action="/api/admin/restaurants" method="POST" style="margin-top: 1.5rem;">
      <div class="form-row" style="display: flex; gap: 1.5rem; margin-bottom: 1.5rem;">
        <div class="form-group" style="flex: 1;">
          <label for="name">Restaurant Name</label>
          <input type="text" id="name" name="name" placeholder="e.g. Joe's Pizza" required 
                 style="width: 100%; border: 1px solid #bfcabf; border-radius: 12px; padding: 0.75rem;">
        </div>
        <div class="form-group" style="flex: 1;">
          <label for="camis">CAMIS ID (8 digits)</label>
          <input type="text" id="camis" name="camis" placeholder="12345678" required 
                 style="width: 100%; border: 1px solid #bfcabf; border-radius: 12px; padding: 0.75rem;">
        </div>
      </div>
      <div class="form-row" style="display: flex; gap: 1.5rem; margin-bottom: 1.5rem;">
        <div class="form-group" style="flex: 1;">
          <label for="boro">Borough</label>
          <input type="text" id="boro" name="boro" placeholder="Manhattan" 
                 style="width: 100%; border: 1px solid #bfcabf; border-radius: 12px; padding: 0.75rem;">
        </div>
        <div class="form-group" style="flex: 1;">
          <label for="cuisine">Cuisine Type</label>
          <input type="text" id="cuisine" name="cuisine" placeholder="Italian" 
                 style="width: 100%; border: 1px solid #bfcabf; border-radius: 12px; padding: 0.75rem;">
        </div>
      </div>
      <button type="submit" class="primary-btn" style="width: auto; padding: 0.85rem 3rem;"> Add to Database</button>
    </form>
  </section>

  {{!-- 3. Advanced Management: Global Search --}}
  <section class="home-info-panel" style="margin-top: 2rem; background: var(--white); border: 2px solid var(--green-soft);">
    <div class="eyebrow">Advanced Management</div>
    <h2>Manual Records Search</h2>
    <div class="home-actions" style="margin-top: 1.5rem; grid-template-columns: 1fr 1fr 1fr;">
      
      {{!-- Restaurant Search --}}
      <div class="home-card" style="text-align: left;">
          <h3>Manage Restaurants</h3>
          <p style="font-size: 0.85rem; margin-bottom: 1rem;"> Find and remove by CAMIS or Name. </p>
          <form action="/api/admin/search/restaurants" method="GET" style="display: flex; gap: 0.5rem;">
              <input type="text" name="query" placeholder="Enter Name or ID..." required 
                     style="flex: 1; padding: 0.6rem; border-radius: 8px; border: 1px solid #bfcabf;">
              <button type="submit" class="secondary-btn" style="padding: 0.6rem 1rem; font-size: 0.8rem;">Search</button>
          </form>
      </div>

      {{!-- Review Search --}}
      <div class="home-card" style="text-align: left;">
          <h3>Manage All Reviews</h3>
          <p style="font-size: 0.85rem; margin-bottom: 1rem;"> Search and moderate specific review text. </p>
          <form action="/api/admin/search/reviews" method="GET" style="display: flex; gap: 0.5rem;">
              <input type="text" name="query" placeholder="Enter keywords..." required 
                     style="flex: 1; padding: 0.6rem; border-radius: 8px; border: 1px solid #bfcabf;">
              <button type="submit" class="secondary-btn" style="padding: 0.6rem 1rem; font-size: 0.8rem;">Search</button>
          </form>
      </div>

      {{!-- Post Search --}}
      <div class="home-card" style="text-align: left;">
          <h3>Manage Pulse Posts</h3>
          <p style="font-size: 0.85rem; margin-bottom: 1rem;">Search and moderate Community Pulse content.</p>
          <form action="/api/admin/search/posts" method="GET" style="display: flex; gap: 0.5rem;">
              <input type="text" name="query" placeholder="Enter keywords..." required 
                     style="flex: 1; padding: 0.6rem; border-radius: 8px; border: 1px solid #bfcabf;">
              <button type="submit" class="secondary-btn" style="padding: 0.6rem 1rem; font-size: 0.8rem;">Search</button>
          </form>
      </div>
    </div>
  </section>

  {{!-- 4. NEW: Moderation Hub (Top 20 Priority Items) --}}
  <section class="home-info-panel" style="margin-top: 2rem;">
    <div class="eyebrow">Moderation Hub</div>
    <h2>Priority Flagged Content</h2>
    <p>The following items have received the highest volume of community reports.</p>

    <div class="landing-about" style="margin-top: 1.5rem; display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        
        {{!-- Top Reported Reviews --}}
        <div class="home-card" style="background: #fffafa; border: 1px solid #ffcccc; width: 100%;">
            <h3 style="color: #c0392b; margin-bottom: 1rem;"> Priority Reviews (Top 20)</h3>
            <div style="max-height: 500px; overflow-y: auto; padding-right: 10px;">
                {{#if topReviews.length}}
                    {{#each topReviews}}
                    <div style="padding: 1rem; border-bottom: 1px solid #eee; text-align: left; margin-bottom: 0.5rem; background: white; border-radius: 8px;">
                        <p style="font-size: 0.9rem; line-height: 1.4;">"{{this.comment}}"</p>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;">
                            <span style="background: #e74c3c; color: white; padding: 2px 8px; border-radius: 20px; font-size: 0.75rem; font-weight: bold;">
                                {{this.reportCount}} Reports
                            </span>
                            <form action="/api/admin/reviews/{{this._id}}?_method=DELETE" method="POST">
                                <input type="hidden" name="returnUrl" value="/api/admin/dashboard">
                                <button type="submit" class="primary-btn" style="background: #e74c3c; font-size: 0.7rem; padding: 0.4rem 0.8rem;">Force Remove</button>
                            </form>
                        </div>
                    </div>
                    {{/each}}
                {{else}}
                    <p style="opacity: 0.5; padding: 3rem; text-align: center;">No flagged reviews found.</p>
                {{/if}}
            </div>
        </div>

        {{!-- Top Reported Posts --}}
        <div class="home-card" style="background: #fffafa; border: 1px solid #ffcccc; width: 100%;">
            <h3 style="color: #c0392b; margin-bottom: 1rem;"> Priority Posts (Top 20)</h3>
            <div style="max-height: 500px; overflow-y: auto; padding-right: 10px;">
                {{#if topPosts.length}}
                    {{#each topPosts}}
                    <div style="padding: 1rem; border-bottom: 1px solid #eee; text-align: left; margin-bottom: 0.5rem; background: white; border-radius: 8px;">
                        <h5 style="margin: 0; color: var(--green-dark);">{{this.businessName}}</h5>
                        <p style="font-size: 0.85rem; margin: 0.5rem 0; line-height: 1.4;">{{this.content}}</p>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;">
                            <span style="background: #e74c3c; color: white; padding: 2px 8px; border-radius: 20px; font-size: 0.75rem; font-weight: bold;">
                                {{this.reportCount}} Reports
                            </span>
                            <form action="/api/admin/posts/{{this._id}}?_method=DELETE" method="POST">
                                <input type="hidden" name="returnUrl" value="/api/admin/dashboard">
                                <button type="submit" class="primary-btn" style="background: #e74c3c; font-size: 0.7rem; padding: 0.4rem 0.8rem;">Delete Post</button>
                            </form>
                        </div>
                    </div>
                    {{/each}}
                {{else}}
                    <p style="opacity: 0.5; padding: 3rem; text-align: center;">No flagged posts found.</p>
                {{/if}}
            </div>
        </div>

    </div>
  </section>

  {{!-- 5. Accountability Trail: System Logs --}}
  <section class="home-info-panel" style="margin-top: 2rem;">
      <div class="about-text-content" style="width: 100%;">
        <h2>System Activity Logs</h2>
        <p>Permanent record of all administrative moderations and injections.</p>
        <div style="overflow-x: auto;">
          <table style="width: 100%; text-align: left; border-collapse: collapse; margin-top: 1rem;">
            <thead>
              <tr style="border-bottom: 2px solid var(--green-main);">
                <th style="padding: 12px;">Admin Action</th>
                <th style="padding: 12px;">Target Resource</th>
                <th style="padding: 12px;">Timestamp</th>
              </tr>
            </thead>
            <tbody>
              {{#each systemLogs}}
              <tr style="border-bottom: 1px solid #d8e8d8;">
                <td style="padding: 12px; font-weight: bold; color: var(--green-dark);">{{this.action}}</td>
                <td style="padding: 12px;"><code>{{this.targetId}}</code></td>
                <td style="padding: 12px; font-size: 0.8rem; color: #666;">{{this.timestamp}}</td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          {{#unless systemLogs.length}}
            <p style="margin-top: 2rem; opacity: 0.5; text-align: center;">No logs available.</p>
          {{/unless}}
        </div>
      </div>
  </section>
</div>