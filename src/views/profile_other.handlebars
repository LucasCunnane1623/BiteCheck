<h1 id="h1_big"> {{username}}'s Profile </h1>
<div class="profile_info">
    <p><b>Profile Photo:</b> {{profilePhoto}}</p>

    {{#if profilePhoto}}
    <img src="{{profilePhoto}}" alt="{{username}}'s profile photo" class="profile-photo">
    {{else}}
    <p>No profile photo uploaded.</p>
    {{/if}}

    <p><b>First Name:</b> {{firstName}}</p>
    
    <p><b>Last Name:</b> {{lastName}}</p>

    <p><b>Status:</b> {{status}}</p>

    <p><b>App Search Radius:</b> {{appSearchRadiusMeters}} meters</p>

    <p><b>Favorite Restaurants:</b> 
    {{#if hasRestaurants}}
        {{#each favRestaurants}}
            <li>{{this}}</li>  
        {{/each}}
    {{else}}No favorite restaurants yet.
    {{/if}}</p>
{{!-- these are the NON editable fields of the users profile (ie. they can't be changed from a form submission) --}}
    <p><b>Age Upon Registration:</b> {{age}}</p>

    <p><b>Email:</b> {{email}}</p>

    <h2>Recent Posts</h2>
    <ul>
        {{#each recentPosts}}
            <li>
                <p>Posted on {{this.createdOn}}</p>
                <div class="community-post-body">
                    <h4>{{this.businessName}}</h4>
                    <p>{{this.content}}</p>
                </div>
            </li>
        {{/each}}
    </ul>
</div>


<div class="button-grid">
    <div class="home-bottom-actions">
        {{#if fromCommunityPulse}}
            <a href="/api/posts" class="secondary-btn"> 
                Back To Community Pulse
            </a>
        {{else}}
            <a href="/api/users/friends" class="secondary-btn"> 
                Back To Friends List
            </a>
        {{/if}}
    </div>
</div>
