<section class="landing-page">
    <section class="landing-hero">
        <div class="landing-hero-text">
            <p class="eyebrow">Public health dining transparency</p>
            <h1>{{header}}</h1>
            <p>
                Search restaurant inspection information and make safer dining choices
                before deciding where to eat.
            </p>

            <div class="landing-buttons">
                <a href="/api/auth/register" class="primary-btn landing-btn">Get Started</a>
                <a href="/api/auth/login" class="secondary-btn landing-btn">Sign In</a>
            </div>
        </div>

        <div class="landing-hero-logo">
            <img src="/images/logo.png" alt="BiteCheck official logo">
        </div>
    </section>

    <section class="landing-about">
        <div class="about-side">
            <div class="about-badge">
                <span>What is</span>
                <strong>BiteCheck?</strong>
            </div>
        </div>

        <div class="about-text">
            <div class="about-text-content">
                {{{body}}}
            </div>

            <img class="about-text-image" src="/images/person_food.png" alt="Person made of healthy foods">
        </div>
    </section>

    <section class="landing-feature-grid">
        <article class="landing-feature-card">
            <h2>Official Data</h2>
            <p>
                BiteCheck is built around restaurant inspection information instead of only
                crowdsourced reviews.
            </p>
        </article>

        <article class="landing-feature-card">
            <h2>Health Focused</h2>
            <p>
                The app highlights safety and hygiene information that can impact dining decisions.
            </p>
        </article>

        <article class="landing-feature-card">
            <h2>Easy to Use</h2>
            <p>
                Users can quickly sign up, log in, and search for restaurant safety information.
            </p>
        </article>
    </section>
</section>
