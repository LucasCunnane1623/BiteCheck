<section class="home-page">
    <section class="home-hero">
        <p class="eyebrow">BiteCheck Dashboard</p>
        <h1>{{header}}</h1>
        <p>
            Welcome back. Use BiteCheck to search restaurant information, review safety details,
            and make cleaner dining decisions.
        </p>
    </section>

    <section class="home-actions">
        <a class="home-card" href="/restaurants/search">
            <h2>Search Restaurants</h2>
            <p>Search restaurants by name, cuisine, or keyword.</p>
        </a>

        <a class="home-card" href="/restaurants/suggestions">
            <h2>Restaurant Suggestions</h2>
            <p>View suggestions by keyword or based on your favorite restaurants.</p>
        </a>

        <a class="home-card" href="/">
            <h2>Landing Page</h2>
            <p>Return to the BiteCheck welcome page.</p>
        </a>

        <a class="home-card" href="/map">
            <h2>Live Safety Map</h2>
            <p>View restaurant safety ratings on an interactive map.</p>
        </a>
    </section>

    <section class="home-info-panel">
        <h2>About This Page</h2>
        <p>
            {{{body}}}
        </p>
        <p>
            This dashboard is the signed-in landing area for BiteCheck users.
        </p>
    </section>

    <div class="home-bottom-actions">
        <a href="/api/auth/logout" class="secondary-btn">Sign Out</a>
    </div>
</section>
