<section class="restaurant-page">
    <section class="restaurant-hero">
        <div class="eyebrow">Safety Intelligence</div>
        <h1>Restaurant Search</h1>
        <p>Proactive community safety markers and official NYC health status.</p>
    </section>

    <div class="restaurant-results-scroll-container">
        {{#if results.length}}
            {{#each results}}
                <article class="restaurant-result-list-item {{#if this.isAtRisk}}at-risk-border{{/if}}">
                    <div class="result-main-info">
                        <div class="result-header">
                            <h3>{{this.name}}</h3>
                            <span class="safety-pill {{this.safetyStatus}}">{{this.safetyStatus}}</span>
                            <span class="trend-badge">{{this.trend}}</span>
                        </div>
                        
                        <div class="result-meta">
                            <span><b>Borough:</b> {{this.boro}}</span>
                            <span class="meta-sep">|</span>
                            <span><b>CAMIS:</b> <code>{{this.camis}}</code></span>
                            <span class="meta-sep">|</span>
                            <span><b>Cuisine:</b> {{this.cuisine}}</span>
                        </div>

                        <div class="violation-tag-list">
                            {{#each this.violationTags}}
                                <span class="v-tag">{{this}}</span>
                            {{/each}}
                        </div>
                    </div>

                    <div class="result-pulse-actions">
                        <div class="community-pulse-mini">
                            {{#if this.reviewCount}}
                                <span title="Has Community Reviews">💬</span>
                            {{/if}}
                            
                            {{#if this.reportCount}}
                                <span title="Safety Reports Present" class="has-reports">🚩</span>
                            {{/if}}
                        </div>
                    </div>
                </article>
            {{/each}}
        {{else}}
            <div class="empty-community-card" style="text-align: center; padding: 4rem;">
                <h3>No establishments found for "{{query}}"</h3>
                <p>Try searching for a different borough or cuisine.</p>
            </div>
        {{/if}}
    </div>
</section>


